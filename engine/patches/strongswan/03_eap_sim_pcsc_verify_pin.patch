--- a/src/libcharon/plugins/eap_sim_pcsc/eap_sim_pcsc_card.c
+++ b/src/libcharon/plugins/eap_sim_pcsc/eap_sim_pcsc_card.c
@@ -549,6 +549,68 @@
 			continue;
 		}
 
+		/* --- VoWiFi patch: VERIFY CHV1 (SIM PIN) before AUTHENTICATE ------------
+		 * Upstream assumes CHV1 is already verified out-of-band (a separate held
+		 * PC/SC connection keeps the card powered). That assumption breaks on tunnel
+		 * RE-establishment: this fresh connection can find CHV1 no longer satisfied,
+		 * so AUTHENTICATE returns 0x6982 and EAP-AKA re-auth fails, leaving the tunnel
+		 * unable to recover. We VERIFY CHV1 here, in THIS connection, right before
+		 * AUTHENTICATE, so re-auth is self-contained.
+		 *
+		 * Gated on the USIM_PIN env (exported by the engine entrypoint): if it is
+		 * unset/empty/"none"/"disabled" the SIM has no usable PIN, so we skip the whole
+		 * block and behave EXACTLY as upstream (PIN-less / PIN-disabled SIMs unaffected).
+		 * We first read the remaining-tries counter with an Lc=0 VERIFY (consumes no
+		 * try): if CHV1 is already satisfied (0x9000) we skip, and if fewer than 2 tries
+		 * remain we skip to avoid a PUK lock. Re-verifying a satisfied CHV1 with the
+		 * correct PIN returns 0x9000 and does not spend a try. */
+		{
+			const char *pin_env = getenv("USIM_PIN");
+			if (pin_env && *pin_env &&
+				strcmp(pin_env, "none") != 0 && strcmp(pin_env, "disabled") != 0)
+			{
+				size_t pin_len = strlen(pin_env);
+				static const BYTE pbChv1Status[] = { 0x00, 0x20, 0x00, 0x01, 0x00 };
+				int chv1_tries = -1; /* -1 => already verified / not required */
+
+				dwRecvLength = sizeof(pbRecvBuffer);
+				rv = SCardTransmit(hCard, pioSendPci, pbChv1Status, sizeof(pbChv1Status),
+								   &pioRecvPci, pbRecvBuffer, &dwRecvLength);
+				if (rv == SCARD_S_SUCCESS && dwRecvLength >= APDU_STATUS_LEN)
+				{
+					BYTE sw1 = pbRecvBuffer[dwRecvLength-APDU_STATUS_LEN];
+					BYTE sw2 = pbRecvBuffer[dwRecvLength-APDU_STATUS_LEN+1];
+					if (sw1 == 0x63) { chv1_tries = sw2 & 0x0F; }
+					else if (sw1 == 0x69 && sw2 == 0x83) { chv1_tries = 0; }
+				}
+				if (chv1_tries >= 2 && pin_len >= 4 && pin_len <= 8)
+				{
+					BYTE pbVerifyChv1[5 + 8] = { 0x00, 0x20, 0x00, 0x01, 0x08,
+						0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF };
+					memcpy(pbVerifyChv1 + 5, pin_env, pin_len);
+
+					dwRecvLength = sizeof(pbRecvBuffer);
+					rv = SCardTransmit(hCard, pioSendPci, pbVerifyChv1, sizeof(pbVerifyChv1),
+									   &pioRecvPci, pbRecvBuffer, &dwRecvLength);
+					if (rv == SCARD_S_SUCCESS && dwRecvLength >= APDU_STATUS_LEN &&
+						pbRecvBuffer[dwRecvLength-APDU_STATUS_LEN] == APDU_SW1_SUCCESS)
+					{
+						DBG2(DBG_IKE, "VoWiFi: VERIFY CHV1 ok before AUTHENTICATE");
+					}
+					else
+					{
+						DBG1(DBG_IKE, "VoWiFi: VERIFY CHV1 rejected: %b",
+							 pbRecvBuffer, (u_int)dwRecvLength);
+					}
+				}
+				else if (chv1_tries >= 0 && chv1_tries < 2)
+				{
+					DBG1(DBG_IKE, "VoWiFi: only %d CHV1 tries left, skipping VERIFY (PUK risk)",
+						 chv1_tries);
+				}
+			}
+		}
+
 		/* Copy RAND + AUTN into APDU */
 		memcpy(pbAuthenticate + 6, rand, AKA_RAND_LEN);
 		pbAuthenticate[6 + AKA_RAND_LEN] = 0x10;
