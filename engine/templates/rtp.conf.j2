[general]
rtpstart={{ rtp_start }}
rtpend={{ rtp_end }}
{% if webrtc_enable and advertise_addr %}
; WebRTC needs ICE (an RTP-level feature — lives here, not in pjsip.conf). webrtc=yes turns on
; ice_support at the endpoint, but the ICE agent only gathers candidates when icesupport=yes.
icesupport=yes
; A docker bridge is a 1:1 NAT: the only host candidate Asterisk gathers is its container-
; private RTP bind address ({{ rtp_bind_addr }}), which a LAN browser (e.g. 192.168.1.x) cannot
; reach. Rewrite it to the host LAN IP whose RTP ports are published so the browser's SRTP
; lands on us. include_local_address ALSO keeps the container address as a candidate, so ICE
; picks whichever the peer can actually reach (robust if the container IP shifts).
; No stunaddr: both peers are on the LAN and the reachable address is statically known (docs
; warn against mixing stunaddr/turnaddr with an explicit [ice_host_candidates] mapping).
[ice_host_candidates]
{{ rtp_bind_addr }} => {{ advertise_addr }},include_local_address
{% endif %}
